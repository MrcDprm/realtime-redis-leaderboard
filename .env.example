# Copy this file to `.env` and replace every CHANGE_ME value before starting.
# Never commit a real `.env` file.

# PostgreSQL
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=leaderboard_db

# Backend
# Format: postgresql://USER:PASSWORD@postgres-db:5432/DB_NAME?schema=public
DATABASE_URL=postgresql://CHANGE_ME:CHANGE_ME@postgres-db:5432/leaderboard_db?schema=public
REDIS_URL=redis://redis-cache:6379
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=production
CORS_ORIGIN=http://localhost:8080

# Frontend build-time (leave empty to use same-origin nginx proxy)
VITE_API_URL=
VITE_SOCKET_URL=

# PostgreSQL
POSTGRES_USER=leaderboard
POSTGRES_PASSWORD=leaderboard_secret
POSTGRES_DB=leaderboard_db

# Backend
DATABASE_URL=postgresql://leaderboard:leaderboard_secret@postgres-db:5432/leaderboard_db?schema=public
REDIS_URL=redis://redis-cache:6379
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
PORT=5000
NODE_ENV=production
CORS_ORIGIN=http://localhost:8080

# Frontend build-time (used by Vite inside Docker)
VITE_API_URL=
VITE_SOCKET_URL=
